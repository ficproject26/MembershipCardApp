generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Agent {
  id            String         @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  email         String         @unique
  phoneNumber   String         @unique
  agentCode     String         @unique
  password      String?
  isEmailVerified   Boolean        @default(false)
  verificationToken String?
  resetToken        String?
  resetTokenExpiry  DateTime?
  membership    String         @default("Silver") // Silver, Gold, Diamond, Platinum
  referredById  String?        @db.ObjectId
  referredBy    Agent?         @relation("Referrals", fields: [referredById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  referrals     Agent[]        @relation("Referrals")
  walletBalance Float          @default(0.0)
  totalEarnings Float          @default(0.0)
  kycStatus         String         @default("NotSubmitted") // NotSubmitted, Pending, Approved, Rejected
  aadhaarNumber     String?
  panNumber         String?
  bankAccountNumber String?
  bankIfscCode      String?
  bankAccountName   String?
  photoUrl          String?
  fcmToken      String?
  dateJoined    DateTime       @default(now())

  leads         Lead[]
  transactions  Transaction[]
}

model Lead {
  id              String     @id @default(auto()) @map("_id") @db.ObjectId
  agentId         String     @db.ObjectId
  agent           Agent      @relation(fields: [agentId], references: [id])
  customerName    String?
  customerPhone   String?
  customerEmail   String?
  serviceType     String
  details         String     @default("{}") // Store JSON string since SQLite doesn't natively support JSON
  status          String     @default("Pending") // Pending, Approved, Stage1Pending...
  rejectionReason String?
  bankMessage     String?
  kycLink         String?    // Unique token for public KYC upload page
  dateCreated     DateTime   @default(now())
  kycDocuments    KycDocument[]
}

model KycDocument {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  leadId        String   @db.ObjectId
  lead          Lead     @relation(fields: [leadId], references: [id])
  docType       String   // "aadhaar_front", "aadhaar_back", "pan_card", "live_photo", "passport_photo"
  aadhaarNumber String?
  panNumber     String?
  filePath      String   // Path to saved file on server
  uploadedAt    DateTime @default(now())
}

model Transaction {
  id          String            @id @default(auto()) @map("_id") @db.ObjectId
  agentId     String            @db.ObjectId
  agent       Agent             @relation(fields: [agentId], references: [id])
  amount      Float
  type        String            // Withdrawal, Upgrade, DirectCommission...
  status      String            @default("Pending") // Pending, Success, Rejected
  description String
  date        DateTime          @default(now())
}

model MembershipPricing {
  id       String         @id @default(auto()) @map("_id") @db.ObjectId
  tier     String         @unique
  price    Float
  benefits String         // Comma separated list
}

model CommissionConfig {
  id           String @id @default(auto()) @map("_id") @db.ObjectId
  serviceType  String @unique
  directRate   Float
  indirectRate Float
}

model Staff {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  email       String   @unique
  phoneNumber String   @unique
  role        String   // HR, KYC, CreditCardTL, LoanTL, etc.
  department  String?
  password    String?
  fcmToken    String?
  dateJoined  DateTime @default(now())
}

model Message {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  senderId     String
  senderType   String   // 'Agent', 'Staff', 'Admin'
  receiverId   String
  receiverType String   // 'Agent', 'Staff', 'Admin'
  content      String
  type         String   @default("TEXT") // TEXT, IMAGE, VIDEO
  mediaUrl     String?
  isRead       Boolean  @default(false)
  createdAt    DateTime @default(now())
}

model StatusUpdate {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String
  userName  String
  content   String?
  type      String   @default("TEXT") // TEXT, IMAGE, VIDEO
  mediaUrl  String?
  createdAt DateTime @default(now())
}
